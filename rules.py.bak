# === grayhole ===


import pandas as pd

def detect_grayhole(df, stdiff_threshold=10, sqdiff_threshold=5, stnum_elevated=1000):
    """
    Detect potential grayhole behavior in IEC 61850 GOOSE traffic.

    Parameters
    ----------
    df : pandas.DataFrame
        Must contain columns 'StNum' and 'SqNum'.
    stdiff_threshold : float, optional
        Minimum stDiff considered excessive (default 10).
    sqdiff_threshold : float, optional
        Maximum sqDiff considered abnormally low (default 5).
    stnum_elevated : int, optional
        Minimum StNum considered elevated (default 1000).

    Returns
    -------
    pandas.DataFrame
        Rows flagged as suspicious with an added 'Reason' column.
    """
    # Ensure required columns exist
    required = {'StNum', 'SqNum'}
    if not required.issubset(df.columns):
        raise ValueError(f"Input DataFrame must contain columns: {required}")

    # Compute differences
    df = df.copy()
    df['stDiff'] = df['StNum'].diff()
    df['sqDiff'] = df['SqNum'].diff()

    # Flag conditions
    cond_excessive_stdiff = df['stDiff'] > stdiff_threshold
    cond_low_sqdiff = df['sqDiff'] < sqdiff_threshold
    cond_elevated_stnum = df['StNum'] > stnum_elevated

    # Combine flags
    flagged = df[cond_excessive_stdiff | cond_low_sqdiff | cond_elevated_stnum].copy()
    reasons = []
    for _, row in flagged.iterrows():
        r = []
        if row['stDiff'] > stdiff_threshold:
            r.append('Excessive stDiff')
        if row['sqDiff'] < sqdiff_threshold:
            r.append('Abnormally low sqDiff')
        if row['StNum'] > stnum_elevated:
            r.append('Elevated StNum')
        reasons.append('; '.join(r))
    flagged['Reason'] = reasons

    return flagged

# Example usage
if __name__ == "__main__":
    sample_data = pd.DataFrame({
        'StNum': [1, 2, 3, 113, 114, 115, 2000],
        'SqNum': [10, 20, 30, 32, 42, 52, 60]
    })
    suspicious = detect_grayhole(sample_data)
    print(suspicious)


# === high_StNum ===


def rule_high_StNum_jumps_stnum_time_diff(packet: dict) -> bool:
    stnum = packet.get('StNum', 0)
    stnum_diff = packet.get('stDiff', 0)
    timestamp_diff = packet.get('timestampDiff', 0)
    if stnum_diff > 5 and timestamp_diff < 5:
        return True
    if stnum_diff > 1000 and timestamp_diff < 60:
        return True
    return False

def rule_high_StNum_sqnum_reset_pattern(packet: dict) -> bool:
    sqnum = packet.get('SqNum', 0)
    sqnum_diff = packet.get('sqDiff', 0)
    stnum_diff = packet.get('stDiff', 0)
    if sqnum_diff > 2 and stnum_diff > 1:
        return True
    if sqnum == 0 and stnum_diff > 1:
        return True
    return False

def rule_high_StNum_abnormal_cbstatus_shift(packet: dict) -> bool:
    cbstatus = packet.get('cbStatus', 0)
    cbstatus_diff = packet.get('cbStatusDiff', 0)
    stnum_diff = packet.get('stDiff', 0)
    if cbstatus_diff > 0.5 and stnum_diff > 1:
        return True
    if cbstatus > 0.5 and stnum_diff > 5:
        return True
    return False

def rule_high_StNum_static_payload_size(packet: dict) -> bool:
    goose_length_diff = packet.get('gooseLengthDiff', 0)
    apdu_size_diff = packet.get('apduSizeDiff', 0)
    stnum_diff = packet.get('stDiff', 0)
    if goose_length_diff == 0 and apdu_size_diff == 0 and stnum_diff > 1:
        return True
    return False

def rule_high_StNum_excessive_stnum_jump(packet: dict) -> bool:
    stnum = packet.get('StNum', 0)
    stnum_diff = packet.get('stDiff', 0)
    if stnum_diff > 100:
        return True
    if stnum > 1000 and stnum_diff > 10:
        return True
    return False


# === injection ===


def rule_injection_jumps_stnum_time_diff(packet: dict) -> bool:
    stnum = packet.get('StNum', 0)
    stnum_diff = packet.get('stDiff', 0)
    timestamp_diff = packet.get('timestampDiff', 0)
    return stnum_diff < -1000 and timestamp_diff < -3000

def rule_injection_sqnum_reset_pattern(packet: dict) -> bool:
    sqnum = packet.get('SqNum', 0)
    sqnum_diff = packet.get('sqDiff', 0)
    return sqnum_diff > 10 and sqnum > 100

def rule_injection_elevated_cbstatus_change(packet: dict) -> bool:
    cbstatus = packet.get('cbStatus', 0)
    cbstatus_diff = packet.get('cbStatusDiff', 0)
    return cbstatus_diff > 0.5 and cbstatus > 0.5

def rule_injection_static_payload_size(packet: dict) -> bool:
    goose_length_diff = packet.get('gooseLengthDiff', 0)
    apdu_size_diff = packet.get('apduSizeDiff', 0)
    return goose_length_diff == 0 and apdu_size_diff == 0

def rule_injection_stnum_value_collapse(packet: dict) -> bool:
    stnum = packet.get('StNum', 0)
    stnum_diff = packet.get('stDiff', 0)
    return stnum_diff < -100 and stnum < 100


# === inverse_replay ===


def rule_inverse_replay_stnum_jump(packet: dict) -> bool:
    """Retorna True se o pacote for suspeito desse ataque."""
    stnum = packet.get('StNum', 0)
    prev_stnum = packet.get('prev_StNum', 0)
    st_diff = packet.get('stDiff', 0)
    return (stnum - prev_stnum) > 5 and st_diff > 5

def rule_inverse_replay_sqnum_decrease(packet: dict) -> bool:
    """Retorna True se o pacote for suspeito desse ataque."""
    sqnum = packet.get('SqNum', 0)
    prev_sqnum = packet.get('prev_SqNum', 0)
    sq_diff = packet.get('sqDiff', 0)
    return (sqnum - prev_sqnum) < 0 and sq_diff < 0

def rule_inverse_replay_timestamp_seq_mismatch(packet: dict) -> bool:
    """Retorna True se o pacote for suspeito desse ataque."""
    st_diff = packet.get('stDiff', 0)
    sq_diff = packet.get('sqDiff', 0)
    return st_diff > 5 and sq_diff < 0

def rule_inverse_replay_ethsrc_stnum_anomaly(packet: dict) -> bool:
    """Retorna True se o pacote for suspeito desse ataque."""
    eth_src = packet.get('ethSrc', '')
    st_diff = packet.get('stDiff', 0)
    return eth_src.startswith('00:11') and st_diff > 5


# === masquerade_fake_fault ===


def rule_masquerade_fake_fault_sqnum_regression_and_low_abs(packet: dict) -> bool:
    """Detecta regressão de SqNum associada a valores absolutos baixos."""
    sq_diff = packet.get('sqDiff', 0)
    sq_num = packet.get('SqNum', 0)
    return sq_diff < -10 and sq_num < 10

def rule_masquerade_fake_fault_stnum_jump_and_timestamp(packet: dict) -> bool:
    """Detecta salto grande em StNum combinado com diferença de timestamp fora do normal."""
    st_diff = packet.get('stDiff', 0)
    ts_diff = packet.get('timestampDiff', 0)
    return st_diff > 5 and ts_diff > 100

def rule_masquerade_fake_fault_cbstatus_elevation_and_stnum_jump(packet: dict) -> bool:
    """Detecta elevação inesperada de cbStatus junto a salto em StNum."""
    cb_status = packet.get('cbStatus', 0)
    st_diff = packet.get('stDiff', 0)
    return cb_status > 0.8 and st_diff > 5

def rule_masquerade_fake_fault_inconsistent_timing_and_sqnum_regression(packet: dict) -> bool:
    """Detecta padrão inconsistente de tempo associado à regressão de SqNum."""
    sq_diff = packet.get('sqDiff', 0)
    st_diff = packet.get('stDiff', 0)
    ts_diff = packet.get('timestampDiff', 0)
    return sq_diff < 0 and st_diff > 5 and ts_diff > 100

def rule_masquerade_fake_fault_src_dst_change_with_counters(packet: dict) -> bool:
    """Detecta mudança de endereços MAC combinada com variação anômala de contadores."""
    eth_src = packet.get('ethSrc', '')
    eth_dst = packet.get('ethDst', '')
    st_diff = packet.get('stDiff', 0)
    sq_diff = packet.get('sqDiff', 0)
    return eth_src != eth_dst and (st_diff > 5 or sq_diff < -10)


# === masquerade_fake_normal ===


def rule_masquerade_fake_normal_jumps_stnum(packet: dict) -> bool:
    stnum = packet.get('StNum', 0)
    stnum_diff = packet.get('stNumDiff', 0)
    return stnum_diff > 500 and stnum > 1000

def rule_masquerade_fake_normal_sqnum_regression(packet: dict) -> bool:
    sqnum = packet.get('SqNum', 0)
    sqnum_diff = packet.get('sqNumDiff', 0)
    return sqnum_diff < -5 and sqnum < 10

def rule_masquerade_fake_normal_time_reversal(packet: dict) -> bool:
    timestamp_diff = packet.get('timestampDiff', 0)
    return timestamp_diff < -10000

def rule_masquerade_fake_normal_stnum_sqnum_mismatch(packet: dict) -> bool:
    stnum = packet.get('StNum', 0)
    sqnum = packet.get('SqNum', 0)
    stnum_diff = packet.get('stNumDiff', 0)
    sqnum_diff = packet.get('sqNumDiff', 0)
    return stnum_diff > 100 and sqnum_diff < 0

def rule_masquerade_fake_normal_negative_sqnum_diff(packet: dict) -> bool:
    sqnum_diff = packet.get('sqNumDiff', 0)
    return sqnum_diff < 0


# === poisoned_high_rate ===


**Red‑flag analysis for the *poisoned_high_rate* GOOSE stream**

| Metric | Normal (mean) | Attack (mean) | Observation |
|--------|---------------|---------------|-------------|
| **StNum** (status number) | ≈ 380.7 | ≈ 3528.0 | ≈ 9 × higher – an abnormal jump that is far beyond the usual incremental changes. |
| **SqNum** (sequence number) | ≈ 17.4 | ≈ 1.0 | drastic drop / reset – the sequence counter rolls back to a very low value. |
| **stDiff** (timestamp / status‑change delta) | ≈ +1 ms | ≈ ‑1169 ms | large negative jump – timestamps move backwards, indicating possible replay or timestamp spoofing. |
| **sqDiff** (timestamp / sequence‑change delta) | ≈ +10 ms | ≈ ‑16 ms | negative interval – frames are emitted out‑of‑order or with a fabricated interval. |
| **cbStatus**, **gooseLengthDiff**, **cbStatusDiff**, **apduSizeDiff** | unchanged | unchanged | no discriminating power. |

**Why these fields matter**

* **StNum** must increase only when the data set changes. A huge jump suggests fabricated status updates or a replay/loop attack.
* **SqNum** must increase monotonically (wrapping only at 65535). A sudden reset to 1 breaks this guarantee and is a classic sign of a malicious packet stream.
* **stDiff** and **sqDiff** are derived timing differences. Negative values mean the packet’s timestamp is earlier than the previous one, a clear sign of timestamp manipulation and out‑of‑order delivery.

**Combined attack pattern**

1. Inflated `StNum` → fabricated or replayed status updates.  
2. Reset/rollback of `SqNum` → breaks monotonicity.  
3. Negative `stDiff` → timestamp regression.  
4. Negative `sqDiff` → sequence‑interval regression.  

Detecting any one of these, especially together, should raise an alarm.

---

## Python detection‑rule functions

Below are five lightweight rule functions that each combine **two or more** packet fields (as required).  
All functions accept a `packet` dictionary (the GOOSE record) and return `True` when the packet exhibits suspicious behaviour characteristic of the *poisoned_high_rate* class.

```python
def rule_poisoned_high_rate_jumps_stnum(packet: dict) -> bool:
    """
    Detect an unusually large increase in StNum.
    Uses the derived field 'stNumDiff' (current StNum – previous StNum).
    """
    stnum_diff = packet.get('stNumDiff', 0)          # difference to previous StNum
    # A jump > 1000 is far beyond normal operational increments.
    return stnum_diff > 1000


def rule_poisoned_high_rate_sqnum_reset(packet: dict) -> bool:
    """
    Detect a sudden reset or drastic drop of the sequence number.
    Combines current SqNum with the previous value (prev_SqNum).
    """
    sqnum = packet.get('SqNum', 0)
    prev_sqnum = packet.get('prev_SqNum', 0)
    # If the current value is less than 10 % of the previous one, treat as a reset.
    return sqnum < prev_sqnum * 0.1


def rule_poisoned_high_rate_stdiff_regression(packet: dict) -> bool:
    """
    Detect a large negative timestamp regression between status changes.
    Uses the derived field 'stDiff' (time between successive status‑change events).
    """
    st_diff = packet.get('stDiff', 0)                # in milliseconds
    # A negative jump larger than -100 ms is highly abnormal.
    return st_diff < -100


def rule_poisoned_high_rate_sqdiff_negative(packet: dict) -> bool:
    """
    Detect a negative interval between consecutive GOOSE frames.
    Uses the derived field 'sqDiff' (time between frames based on SqNum).
    """
    sq_diff = packet.get('sqDiff', 0)                # in milliseconds
    return sq_diff < 0


def rule_poisoned_high_rate_combined(packet: dict) -> bool:
    """
    Strongest indicator: all four anomalous behaviours appear together.
    Combines:
      - Large StNum jump (stNumDiff)
      - SqNum reset (current vs previous)
      - Negative stDiff
      - Negative sqDiff
    """
    stnum_diff = packet.get('stNumDiff', 0)
    sqnum = packet.get('SqNum', 0)
    prev_sqnum = packet.get('prev_SqNum', 0)
    st_diff = packet.get('stDiff', 0)
    sq_diff = packet.get('sqDiff', 0)

    return (
        stnum_diff > 1000 and
        sqnum < prev_sqnum * 0.1 and
        st_diff < -100 and
        sq_diff < 0
    )
```

### How to use the rules

```python
# Example packet (normally obtained from a parsed PCAP or live capture)
packet = {
    'StNum': 3528,
    'stNumDiff': 3147,          # current – previous
    'SqNum': 1,
    'prev_SqNum': 18,
    'stDiff': -1169.2,
    'sqDiff': -16.0,
    # other fields (cbStatus, ethSrc, etc.) are ignored by these rules
}

# Apply each rule
suspicious = any([
    rule_poisoned_high_rate_jumps_stnum(packet),
    rule_poisoned_high_rate_sqnum_reset(packet),
    rule_poisoned_high_rate_stdiff_regression(packet),
    rule_poisoned_high_rate_sqdiff_negative(packet),
    rule_poisoned_high_rate_combined(packet),
])

print("Packet flagged as poisoned_high_rate:", suspicious)
```

Each rule respects the constraints:

* **No use of a `class` attribute.**  
* **Only fields present in the dataset** (`StNum`, `SqNum`, `stNumDiff`, `prev_SqNum`, `stDiff`, `sqDiff`).  
* **Combines two or more fields** (e.g., `stNumDiff` + threshold, `SqNum` + `prev_SqNum`).  
* **Relies on relative/behavioral comparisons** (greater‑than, less‑than, proportional checks).  
* **No external libraries** – pure Python logic.  

Deploy these functions inside an intrusion‑detection pipeline; any packet that triggers at least one rule should be treated as a candidate for the *poisoned_high_rate* attack and logged or blocked according to your security policy.


# === random_replay ===


import pandas as pd

def detect_random_replay(df, stdiff_threshold=10):
    """
    Detect red flags for random replay attacks in IEC 61850 GOOSE traffic.
    
    Parameters
    ----------
    df : pandas.DataFrame
        Must contain columns: 'Timestamp' (float or datetime), 'StNum' (numeric), 'SqNum' (int).
    stdiff_threshold : float, optional
        Threshold for excessive timestamp jump (default 10).
    
    Returns
    -------
    dict
        Flags indicating presence of each red flag.
    """
    # Ensure proper ordering by timestamp
    df = df.sort_values('Timestamp').reset_index(drop=True)

    # Compute timestamp difference (stDiff)
    df['stDiff'] = df['Timestamp'].diff().fillna(0)

    # Flag 1: Excessive stDiff
    excessive_stdiff = df['stDiff'].gt(stdiff_threshold).any()

    # Flag 2: Abnormal StNum reset (any decrease compared to previous max)
    df['StNum_max_sofar'] = df['StNum'].cummax()
    abnormal_stnum = (df['StNum'] < df['StNum_max_sofar']).any()

    # Flag 3: Inconsistent SqNum progression (should increase by 1)
    df['SqNum_diff'] = df['SqNum'].diff().fillna(0)
    inconsistent_sqnum = ~df['SqNum_diff'].isin([0, 1]).all()

    return {
        'excessive_stdiff': excessive_stdiff,
        'abnormal_stnum': abnormal_stnum,
        'inconsistent_sqnum': inconsistent_sqnum
    }

# Example usage
if __name__ == "__main__":
    data = {
        'Timestamp': [0, 1, 2, 250, 251],   # large jump at index 3
        'StNum':     [380.7, 381.7, 382.7, 315.0, 383.7],
        'SqNum':     [10, 11, 12, 13, 15]    # non‑sequential increment at last row
    }
    df = pd.DataFrame(data)
    flags = detect_random_replay(df, stdiff_threshold=10)
    print(flags)
